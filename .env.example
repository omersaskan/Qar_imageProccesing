# ============================================================
# Meshysiz Product Asset Factory — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your environment.

# --- Core ---
RECON_ENGINE_PATH=C:\colmap\COLMAP.bat
OPENMVS_BIN_PATH=C:\openmvs\vc17\x64\Release
DATA_ROOT=data
ENV=local_dev
RECON_PIPELINE=colmap_dense
EXPECTED_PRODUCT_COLOR=white_cream

# --- GPU ---
RECON_USE_GPU=true
RECON_GPU_INDEX=0
RECON_MAX_IMAGE_SIZE=2000
RECON_MATCHER=exhaustive

# --- COLMAP StereoFusion ---
RECON_STEREO_FUSION_MIN_NUM_PIXELS=1
RECON_STEREO_FUSION_MAX_REPROJ_ERROR=4
RECON_STEREO_FUSION_MAX_DEPTH_ERROR=0.03
RECON_STEREO_FUSION_MAX_NORMAL_ERROR=25

# --- Masking Strategy ---
RECON_HYBRID_MASKING=true
RECON_DIAGNOSTIC_ENABLE_UNMASKED=false
RECON_UNMASKED_FALLBACK_ENABLED=false
RECON_FALLBACK_STEPS=["default","denser_frames"]
RECON_FALLBACK_SAMPLE_RATE=5
RECON_DENSER_SAMPLING_RATIO=1.0

# --- Poisson Mesher ---
RECON_POISSON_DEPTH=9
RECON_POISSON_TRIM=8
RECON_POISSON_DEPTH_RETRY=8
RECON_POISSON_TRIM_RETRY=8
RECON_POISSON_TIMEOUT_SEC=300

# --- Mesh Budget / Decimation ---
RECON_MESH_BUDGET_FACES=1000000
RECON_MESH_HARD_LIMIT_FACES=8000000
MAX_FACES_PYTHON_DECIMATION=1500000
RECON_PRE_CLEANUP_TARGET_FACES=300000
RECON_MOBILE_TARGET_FACES=100000

# --- OpenMVS ---
OPENMVS_TEXTURED_OUTPUT=true
OPENMVS_FAIL_HARD=false
REQUIRE_TEXTURED_OUTPUT=true

# --- Texture ---
TEXTURE_MASK_ERODE_PX=3
TEXTURE_REJECT_SUPPORT_CONTAMINATION=true
TEXTURE_REJECT_SUBJECT_CLIPPED=true
TEXTURE_MIN_CLEAN_FRAMES=20
MAX_BLACK_PIXEL_RATIO=0.20
MAX_DOMINANT_BACKGROUND_RATIO=0.15
MIN_ATLAS_COVERAGE_RATIO=0.30
MIN_NEAR_WHITE_RATIO_WHITE_CREAM=0.40

# --- Retry / Timeout ---
MAX_RETRY_COUNT=5
SESSION_TIMEOUT_HOURS=2
MIN_FREE_DISK_GB=5

# --- Texture Optimization ---
TEXTURE_USE_COMPATIBLE_NEUTRALIZATION=true
TEXTURE_RETRY_RAW_ALL=true
TEXTURE_MAX_SELECTED_FRAMES=20
TEXTURE_TEXTURING_TARGET_FACES=60000
TEXTURE_SAFE_TEXTURING_TARGET_FACES=40000
TEXTURE_NATIVE_CRASH_RETRY_FACES=30000

# ============================================================
# PHASE 6.1: SAM2 Segmentation (DEV-SUBSET)
# ============================================================
# ⚠️ SAM2 real inference is active ONLY when ALL conditions met:
#    1. SAM2_ENABLED=true
#    2. Valid checkpoint file at SAM2_CHECKPOINT
#    3. torch and segment-anything-2 packages installed
#
# ⚠️ SAM2 must NEVER become the production default.
# ⚠️ Do NOT commit model weights to the repo.
# ⚠️ Do NOT add torch/sam2 to requirements.txt.
SEGMENTATION_METHOD=legacy
SAM2_ENABLED=false
SAM2_DEVICE=cuda
SAM2_MODEL_CFG=sam2_hiera_l.yaml
SAM2_CHECKPOINT=models/sam2/sam2_hiera_large.pt
SAM2_FALLBACK_TO_LEGACY=true
SAM2_REVIEW_ONLY=true
SAM2_PROMPT_MODE=center_box
SAM2_MAX_FRAMES=0

# ============================================================
# PHASE 6.2: Depth Anything (scaffold only, disabled)
# ============================================================
# ⚠️ NOT active in production. Scaffold config only.
# ⚠️ Depth prior requires clean segmentation FIRST.
# ⚠️ Do NOT use depth to fix dirty masks.
DEPTH_ANYTHING_ENABLED=false
DEPTH_ANYTHING_DEVICE=cuda
DEPTH_ANYTHING_MODEL=depth-anything-v2-small
DEPTH_ANYTHING_CHECKPOINT=models/depth_anything/depth_anything_v2_small.pth
DEPTH_ANYTHING_FALLBACK_TO_NONE=true
DEPTH_ANYTHING_REVIEW_ONLY=true
DEPTH_ANYTHING_MAX_FRAMES=0
#
# Depth prior quality gates:
DEPTH_PRIOR_MIN_SEGMENTATION_IOU=0.85
DEPTH_PRIOR_MAX_LEAKAGE_RATIO=0.05
DEPTH_PRIOR_MIN_MASK_CONFIDENCE=0.75

# ============================================================
# AI COMPLETION POLICY (proposed, not implemented)
# ============================================================
# ⚠️ Generative completion is NOT implemented.
# These flags define future thresholds only.
AI_COMPLETION_ENABLED=false
MIN_OBSERVED_SURFACE_FOR_COMPLETION=0.50
MIN_OBSERVED_SURFACE_FOR_PRODUCTION=0.70
MAX_SYNTHESIZED_SURFACE_FOR_REVIEW=0.50
MAX_SYNTHESIZED_SURFACE_FOR_PRODUCTION=0.20
CRITICAL_REGION_COMPLETION_ALLOWED=false
GENERATIVE_COMPLETION_DEFAULT_STATUS=review_ready

# ============================================================
# PHASE A: AR Mask Preview
# ============================================================
# Lightweight diagnostic mask preview for AR HUD feedback.
SAM_MASK_PREVIEW_ENABLED=false
SEGMENTATION_PREVIEW_PROVIDER=legacy
SAM_MASK_MIN_CONFIDENCE=0.75
SAM_MASK_PREVIEW_TIMEOUT_SEC=5
SAM_MASK_PREVIEW_MAX_IMAGE_SIZE=768
SAM_MASK_PREVIEW_REVIEW_ONLY=true

# ============================================================
# SAM3 Segmentation (Proposed)
# ============================================================
# Text-prompted segmentation using SAM3 models.
SAM3_ENABLED=false
SAM3_DEVICE=cuda
SAM3_MODE=video
SAM3_TEXT_PROMPT=product
SAM3_CHECKPOINT=
SAM3_CONFIG=
SAM3_FALLBACK_TO_SAM2=true
SAM3_REVIEW_ONLY=true
SAM3_MAX_KEYFRAMES=3

# ============================================================
# AI 3D Generation (Phase B/C Scaffolds)
# ============================================================
# ⚠️ Generative 3D is NOT active. Scaffolds for future integration.
AI_3D_PROVIDER=none
AI_3D_PREVIEW_ENABLED=false

SAM3D_ENABLED=false
SAM3D_OUTPUT_FORMAT=glb
SAM3D_REQUIRE_REVIEW=true

MESHY_ENABLED=false
MESHY_API_KEY=
MESHY_REQUIRE_REVIEW=true
