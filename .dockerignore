# === Docker Build Context Exclusions ===
# Git & CI
.git
.github

# Python bytecode & caches
__pycache__
*.pyc
*.py[cod]
*$py.class
.pytest_cache
*.egg-info

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs & test artifacts (stale from dev)
*.log
*.txt
!requirements.txt
!smoke_check.sh

# Stale texture/build artifacts in root
material.mtl
material_0.png
package-lock.json

# Temporary & scratch directories
tmp/
scratch/
data/

# Documentation (not needed in runtime image)
docs/
roadmap.md
gate.md
tasks.md
HANDOFF.md
ARCHITECTURE.MD
RUNBOOK.md
DEPLOYMENT_RUNPOD.md

# UI (optional: mount separately in RunPod)
# ui/
